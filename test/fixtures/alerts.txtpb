    cause: CONSTRUCTION
    effect: UNKNOWN_EFFECT
    header_text {
      translation {
        text: "Change at Braintree"
        language: "en"
      }
    }
    description_text {
      translation {
        text: "For access to Braintree Station during this closure, travel down to the first floor and use the pedestrian crosswalk to enter the station at the street level.\r\nThis closure is due to the South Shore Parking Garages Improvements and Renovations Project. The pedestrian bridge will be replaced by a new garage lobby featuring elevators and stairwells.\r\n\r\nAffected routes:\r\nRed Line\r\n210\r\n230\r\n236\r\nMiddleborough/Lakeville Line\r\nKingston/Plymouth Line"
        language: "en"
      }
    }
  }
}

    header_text {
      translation {
        text: "Wollaston closed"
        language: "en"
      }
    }
    description_text {
      translation {
        text: "Wollaston will be transformed into a modern, fully accessible facility, making the entirety of the Red Line 100% accessible.\r\n\r\nTrains will bypass Wollaston station traveling between North Quincy and Quincy Center. Shuttle buses will run between Wollaston and North Quincy stations with the same frequency as the Red Line.\r\n\r\nShuttle bus stops will be fully accessible. \r\n\r\nVisit www.mbta.com/wollaston for details. \r\n\r\nAffected routes:\r\nRed Line"
        language: "en"
      }
    }
  }
}

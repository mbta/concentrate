    effect: UNKNOWN_EFFECT
    header_text {
      translation {
        text: "Change at Kendall/MIT"
        language: "en"
      }
    }
    description_text {
      translation {
        text: "Access to the Kendall/MIT Station will remain open and accessible on the Main Street side of the station throughout this construction.\r\n \r\nThe pedestrian plaza between Carleton Street and Main Street in Kendall Square will be closed due to the construction of an underground garage. \r\n \r\nCustomers are encouraged to utilize alternative paths to/from the station using the paths on Ames Street, Dock Street, or Wadsworth Street.\r\n\r\nAffected routes:\r\nRed Line"
        language: "en"
      }
    }
  }
}

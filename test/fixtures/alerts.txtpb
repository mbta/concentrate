    cause: UNKNOWN_CAUSE
    effect: DETOUR
    header_text {
      translation {
        text: "Red Line shuttle"
        language: "en"
      }
    }
    description_text {
      translation {
        text: "In preparation for the Wollaston Station closure, shuttle buses will replace Red Line service in both directions between Braintree and North Quincy Stations. \r\n \r\nThere will be no shuttle on Monday, January 22. Regularly scheduled Red Line service will operate.\r\n \r\nAll shuttle bus stops are accessible for persons with disabilities.\r\n \r\nRegularly scheduled service will resume at the start of service the following day.\r\n \r\nShuttling the following stops:\r\nNorth Quincy\r\nWollaston\r\nQuincy Center\r\nQuincy Adams\r\nBraintree\r\n\r\nFor more information, please visit: https://www.mbta.com/wollaston"
        language: "en"
      }
    }
  }
}

    cause: MAINTENANCE
    effect: DETOUR
    header_text {
      translation {
        text: "Red Line shuttle"
        language: "en"
      }
    }
    description_text {
      translation {
        text: "Red Line train service will resume at the start of service on the following Monday. All shuttle bus stops are accessible for persons with disabilities. \r\n\r\nCustomers should expect delays in service due to speed restrictions for a minimum of 48 hours after the weekend track work.\r\n\r\nShuttling the following stops:\r\nKendall/MIT (pick-up/drop-off at Marriott Hotel)\r\nCharles/MGH (inbound shuttle buses at Cambridge St @ Grove St, outbound at Cambridge St @ Charles St near the Liberty Hotel)\r\nPark Street (pick-up/drop-off on Tremont St @ Temple Place) \r\n\r\nFor more information: https://www.mbta.com/longfellow"
        language: "en"
      }
    }
  }
}

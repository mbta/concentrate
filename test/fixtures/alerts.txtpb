    cause: CONSTRUCTION
    effect: UNKNOWN_EFFECT
    header_text {
      translation {
        text: "Change at North Station"
        language: "en"
      }
    }
    description_text {
      translation {
        text: "Customers are advised that the pedestrian route for customers transferring from the Green and Orange Line exits at Causeway and Beverly St into North Station Commuter Rail will be moved slightly to accommodate ongoing construction work. \r\n\r\nAfter crossing Causeway St, pedestrians will use a protected walkway along the east side of Legends Way, directly abutting Portal Park. The walkway will include a barrier and kick-plate for blind and low vision passengers.\r\n\r\nAs an alternative, customers may consider utilizing the west exit from North Station Commuter Rail due to congestion."
        language: "en"
      }
    }
  }
}

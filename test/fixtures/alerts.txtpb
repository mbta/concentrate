entity {
  id: "204363"
  alert {
    active_period {
      start: 1508142600
      end: 1525156200
    }
    informed_entity {
      agency_id: "1"
      route_id: "Orange"
      route_type: 1
      stop_id: "70016"
    }
    informed_entity {
      agency_id: "1"
      route_id: "Orange"
      route_type: 1
      stop_id: "70017"
    }
    cause: CONSTRUCTION
    effect: UNKNOWN_EFFECT
    header_text {
      translation {
        text: "Change at Tufts Medical Center"
        language: "en"
      }
    }
    description_text {
      translation {
        text: "The elevators are being taken out of service to facilitate the replacement of the elevator cabs, hydraulic machines, and associated electrical work. \r\n\r\nShuttle bus service will be provided between Tufts Medical Center (Washington St entrance) and Back Bay Stations. Customers in need of shuttle bus service are asked to see station personnel or utilize a station call box to request assistance. \r\n\r\nAs an alternative, customers can also utilize Silver Line service to Chinatown Station. \r\n\r\nClick here for more information: https://www.mbta.com/sites/default/files/2017-09/tufts-oct16-may1-elevators-shuttles.pdf\r\n\r\nAffected routes:\r\nOrange Line"
        language: "en"
      }
    }
  }
}
entity {
  id: "204364"
  alert {
    active_period {
      start: 1508142600
      end: 1525156200
    }
    informed_entity {
      stop_id: "70016"
    }
    informed_entity {
      stop_id: "70017"
    }
    cause: CONSTRUCTION
    effect: OTHER_EFFECT
    header_text {
      translation {
        text: "elevator unavailable"
        language: "en"
      }
    }
    description_text {
      translation {
        text: "Customers looking to exit the Orange Line at Tufts Medical Center should exit at Back Bay and utilize shuttle bus service to Tufts. Customers looking to board at Tufts Medical Center should utilize shuttle bus service to Back Bay to make Orange Line connections. \r\nCustomers in need of shuttle bus service are asked to see station personnel or utilize a station call box to request assistance.\r\n\r\nAs an alternative, customers can also utilize Silver Line service between Temple Place, Tufts Medical Center, and Chinatown Station.  \r\n\r\nThe elevators are being taken out of service to facilitate the replacement of the elevator cabs, hydraulic machines, and associated electrical work.  \r\n\r\nClick here for more information: https://www.mbta.com/tufts-elevators"
        language: "en"
      }
    }
  }
}
